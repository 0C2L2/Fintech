# Copy this to frontend/.env.local and fill in your ngrok URLs

# Backend API URL - Get this from ngrok when you start the backend tunnel
# Example: https://abc123.ngrok.io
NEXT_PUBLIC_API_URL=https://YOUR_NGROK_BACKEND_URL_HERE

# For local development (comment out NEXT_PUBLIC_API_URL above)
# NEXT_PUBLIC_API_URL=http://localhost:8000
